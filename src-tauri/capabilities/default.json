{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Minimal capability set for Navis. Renderer cannot touch fs/shell directly; all sensitive operations go through typed Rust commands.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:webview:allow-set-webview-focus",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message"
  ]
}
